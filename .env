# Server Configuration
PORT=8081
DEBUG_MODE=true
DEBUG_WHATSMEOW=false

# Redis Configuration
REDIS_URL=localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# Database Configuration (sqlite3 or postgres)
DIALECT_DB=sqlite3
DB_URL=file:data.db?_foreign_keys=on

# API Authentication
API_KEY=your-api-key-here

# Basic Auth (optional, alternative to API_KEY)
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# Google Cloud Storage (optional)
GCS_ENABLED=false
GCS_BUCKET=whatsmiau2
GCS_URL=https://storage.googleapis.com

# Google Cloud Logging (optional)
GCL_APP_NAME=whatsmiau2
GCL_ENABLED=false
GCL_PROJECT_ID=

# Performance Tuning
EMITTER_BUFFER_SIZE=2048
HANDLER_SEMAPHORE_SIZE=512

# Proxy Configuration (optional)
PROXY_ADDRESSES=
PROXY_STRATEGY=RANDOM
PROXY_NO_MEDIA=false

# MercadoPago Configuration (PIX Payments)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxx

# Resend Configuration (Email)
RESEND_API_KEY=re_xxxxx

# AI Configuration (Gemini/OpenAI)
GEMINI_API_KEY=
OPENAI_API_KEY=
# ═══════════════════════════════════════════════════════════════
# LOCAL PROVIDERS
# ═══════════════════════════════════════════════════════════════

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Local LLM (llama.cpp, LM Studio, etc)
LOCAL_LLM_URL=http://localhost:8080/v1
# Ollama VPS
OLLAMA_HOST=http://127.0.0.1:11434

