{
    "meta": {
        "project_name": "Automações Comerciais Integradas - Dashboard",
        "version": "1.0.0",
        "framework_compatibility": [
            "Bootstrap 5",
            "Tailwind CSS"
        ],
        "base_theme": "Modern SaaS / Material UI Clean"
    },
    "color_palette": {
        "primary": {
            "main": "#0D6EFD",
            "hover": "#0B5ED7",
            "active": "#0A58CA",
            "contrast_text": "#FFFFFF"
        },
        "secondary": {
            "main": "#6C757D",
            "light": "#F8F9FA",
            "dark": "#343A40"
        },
        "accent": {
            "success": "#198754",
            "warning": "#FFC107",
            "danger": "#DC3545",
            "info": "#0DCAF0"
        },
        "background": {
            "body": "#F3F4F6",
            "card": "#FFFFFF",
            "sidebar": "#FFFFFF",
            "modal_overlay": "rgba(0, 0, 0, 0.5)"
        },
        "text": {
            "primary": "#212529",
            "secondary": "#6C757D",
            "disabled": "#ADB5BD"
        }
    },
    "typography": {
        "font_family": {
            "main": "'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
            "code": "'Fira Code', monospace"
        },
        "hierarchy": {
            "h1": {
                "size": "2.5rem",
                "weight": "700",
                "line_height": "1.2"
            },
            "h2": {
                "size": "2.0rem",
                "weight": "600",
                "line_height": "1.3"
            },
            "h3": {
                "size": "1.75rem",
                "weight": "600",
                "line_height": "1.3"
            },
            "body_text": {
                "size": "1rem",
                "weight": "400",
                "line_height": "1.5"
            },
            "small": {
                "size": "0.875rem",
                "weight": "400",
                "line_height": "1.4"
            }
        }
    },
    "layout_structure": {
        "grid_system": "12-column responsive grid",
        "sidebar": {
            "width_expanded": "260px",
            "width_collapsed": "70px",
            "position": "fixed_left",
            "z_index": "1000"
        },
        "header": {
            "height": "64px",
            "position": "sticky_top",
            "z_index": "900"
        },
        "spacing": {
            "xs": "4px",
            "sm": "8px",
            "md": "16px",
            "lg": "24px",
            "xl": "32px"
        }
    },
    "components": {
        "buttons": {
            "border_radius": "6px",
            "padding": "0.375rem 0.75rem",
            "font_weight": "500",
            "shadow": "0 1px 2px rgba(0, 0, 0, 0.05)"
        },
        "cards": {
            "background": "#FFFFFF",
            "border_radius": "12px",
            "border": "1px solid #E5E7EB",
            "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
            "padding": "20px"
        },
        "inputs": {
            "height": "42px",
            "border_radius": "6px",
            "border_color": "#CED4DA",
            "focus_ring": "0 0 0 0.25rem rgba(13, 110, 253, 0.25)"
        },
        "modals": {
            "backdrop_blur": "4px",
            "border_radius": "16px",
            "header_border": "none"
        }
    },
    "interactive_elements": {
        "status_indicators": {
            "online": {
                "color": "#198754",
                "label": "Conectado"
            },
            "offline": {
                "color": "#DC3545",
                "label": "Desconectado"
            },
            "pending": {
                "color": "#FFC107",
                "label": "Aguardando Leitura"
            }
        }
    }
}